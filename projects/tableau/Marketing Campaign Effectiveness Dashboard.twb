      <column caption='Customer Age' datatype='integer' name='[Calculation_1103409223475200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR(TODAY())-[Year_Birth]' />
      </column>
      <column caption='Total Spending' datatype='integer' name='[Calculation_1103409223716865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MntWines] + [MntFruits] + [MntMeatProducts] + &#13;&#10;[MntFishProducts] + [MntSweetProducts] + [MntGoldProds]' />
      </column>
      <column caption='Total Purchases' datatype='integer' name='[Calculation_1103409224118274]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[NumWebPurchases] + [NumCatalogPurchases] + [NumStorePurchases]' />
      </column>
      <column caption='Campaign Accepted' datatype='integer' name='[Calculation_1103409224839171]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[AcceptedCmp1] + [AcceptedCmp2] + [AcceptedCmp3] + [AcceptedCmp4] + [AcceptedCmp5]' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column aggregation='None' caption='Customer Age (bin)' datatype='integer' name='[Customer Age (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Calculation_1103409223475200]' peg='0' size='5' />
      </column>
